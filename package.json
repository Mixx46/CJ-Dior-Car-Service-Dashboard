{
  "name": "cj-dior-car-service",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "npx concurrently -n SERVER,CLIENT -c cyan,magenta \"node server/index.js\" \"npm --prefix client run dev\"",
    "server": "node server/index.js",
    "client": "npm --prefix client run dev",
    "setup": "npm install && npm --prefix client install"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.3",
    "react-router-dom": "^7.14.2",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.8.3"
  }
}
